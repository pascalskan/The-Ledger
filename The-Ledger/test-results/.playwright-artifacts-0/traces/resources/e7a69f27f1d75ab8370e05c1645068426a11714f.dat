export function fmt(n) {
  return `£${n.toLocaleString("en-GB", {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2
  })}`;
}
export function getTriggerById(id) {
  return TRIGGER_CATALOGUE_V1.find((t) => t.id === id);
}
export function getActionById(id) {
  return ACTION_CATALOGUE_V1.find((a) => a.id === id);
}
export function getActionsForRule(rule) {
  return rule.actionIds.map(getActionById).filter((a) => a !== void 0);
}
export function filterRulesByStatus(rules, status) {
  if (status === "all") return rules;
  return rules.filter((r) => r.status === status);
}
export function filterRulesByCategory(rules, category) {
  if (category === "all") return rules;
  return rules.filter((r) => r.category === category);
}
export function searchRules(rules, query) {
  if (!query.trim()) return rules;
  const q = query.trim().toLowerCase();
  return rules.filter(
    (r) => r.ruleNumber.toLowerCase().includes(q) || r.name.toLowerCase().includes(q) || r.description.toLowerCase().includes(q)
  );
}

