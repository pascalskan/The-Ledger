export function getFailedEntries(queue) {
  return queue.filter((e) => e.status === "failed");
}
export function getRetryRequiredEntries(queue) {
  return queue.filter((e) => e.status === "retry_required");
}
export function mockRetryEntry(entry) {
  return {
    ...entry,
    status: "retry_required",
    retryCount: entry.retryCount + 1,
    lastRetryAt: (/* @__PURE__ */ new Date()).toISOString()
  };
}
export function formatAvgDuration(ms) {
  if (ms < 1e3) return `${ms}ms`;
  return `${(ms / 1e3).toFixed(1)}s`;
}
