              quantity: labor.hours,
              unitPrice: billableRate,
              amount: laborRevenue,
              approvedAt
            };
            mockInvoiceLineItems.push(laborLine);
            mockFinancialMutations.push({
              id: Math.random().toString(36).substr(2, 9),
