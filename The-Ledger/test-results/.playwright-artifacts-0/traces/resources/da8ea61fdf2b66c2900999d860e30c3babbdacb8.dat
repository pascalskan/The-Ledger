            const recoveryAmount = exp.amount * (1 + markupPercent / 100);
            const entryId = Math.random().toString(36).substr(2, 9);
            const expenseEntry = {
              id: entryId,
              reportId,
              reviewId: item.id,
              jobId: item.jobId,
              description: exp.notes || exp.category,
              amount: exp.amount,
              markupPercent,
