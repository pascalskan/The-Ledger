    (r) => r.exceptionNumber.toLowerCase().includes(q) || (r.jobName?.toLowerCase().includes(q) ?? false) || (r.clientName?.toLowerCase().includes(q) ?? false) || (r.description?.toLowerCase().includes(q) ?? false)
