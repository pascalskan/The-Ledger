      setAuditEntries(getGovernanceAuditLog());
      setSelectedRecord(null);
      toast({
        title: `Governance Action: ${action.charAt(0).toUpperCase() + action.slice(1)}`,
        description: `${result.record.ruleName} — audit record created.`
      });
    }
  }
